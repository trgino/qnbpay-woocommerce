{
    "name": "trgino/qnbpay-woocommerce",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "description": "QNBPay Payment Gateway for WooCommerce",
    "keywords": [
        "woocommerce",
        "woocommerce-qnb",
        "woocommerce-qnbpay",
        "qnb",
        "qnbpay",
        "qnbpay-3d",
        "qnbpay-sanalpos"
    ],
    "homepage": "https://qnbpay.com.tr/",
    "authors": [
        {
            "name": "Cüneyt Çil",
            "email": "trgino@trgino.com",
            "homepage": "https://www.trgino.com/"
        }
    ],
    "support": {
        "email": "trgino@trgino.com"
    },
    "require": {
        "php": ">=7.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "brain/monkey": "^2.6",
        "phpstan/phpstan": "^1.11",
        "szepeviktor/phpstan-wordpress": "^1.3",
        "php-stubs/woocommerce-stubs": "^9.0",
        "yoast/phpunit-polyfills": "^1.1"
    },
    "autoload": {
        "psr-4": {
            "QNBPay\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "QNBPay\\Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "scripts": {
        "lint": "find . -path ./vendor -prune -o -name '*.php' -print0 | xargs -0 -n1 php -l",
        "phpstan": "phpstan analyse --no-progress",
        "test": "phpunit"
    }
}
